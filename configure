#!/bin/sh
# configure â€” generate config.mk for the clax build.
#
# Hand-written (no autoconf). Provides the usual GNU-style knobs:
#   ./configure [--prefix=DIR] [--bindir=DIR] [--datadir=DIR] [--mandir=DIR]
#               [--docdir=DIR] [CC=...] [CFLAGS=...] [LDFLAGS=...]
#
# Then:  make && sudo make install
set -eu

# ----- defaults (GNU directory layout) -----------------------------------
prefix=/usr/local
exec_prefix=
bindir=
datarootdir=
datadir=
mandir=
docdir=

CC=${CC:-}
CFLAGS=${CFLAGS:-}
LDFLAGS=${LDFLAGS:-}

PKG=clax

usage() {
    cat <<EOF
Usage: ./configure [OPTION]... [VAR=VALUE]...

Installation directories:
  --prefix=DIR        install architecture-independent files in DIR
                        [/usr/local]
  --exec-prefix=DIR   install architecture-dependent files in DIR  [PREFIX]
  --bindir=DIR        user executables           [EPREFIX/bin]
  --datarootdir=DIR   read-only arch.-indep. data root  [PREFIX/share]
  --datadir=DIR       read-only arch.-indep. data        [DATAROOTDIR]
  --mandir=DIR        man documentation          [DATAROOTDIR/man]
  --docdir=DIR        documentation root         [DATAROOTDIR/doc/$PKG]

Optional variables (also honoured from the environment):
  CC=COMPILER         C compiler command
  CFLAGS=FLAGS        C compiler flags
  LDFLAGS=FLAGS       linker flags

  -h, --help          display this help and exit
EOF
}

# ----- parse arguments ----------------------------------------------------
for arg in "$@"; do
    case $arg in
        --prefix=*)       prefix=${arg#*=} ;;
        --exec-prefix=*)  exec_prefix=${arg#*=} ;;
        --bindir=*)       bindir=${arg#*=} ;;
        --datarootdir=*)  datarootdir=${arg#*=} ;;
        --datadir=*)      datadir=${arg#*=} ;;
        --mandir=*)       mandir=${arg#*=} ;;
        --docdir=*)       docdir=${arg#*=} ;;
        CC=*)             CC=${arg#*=} ;;
        CFLAGS=*)         CFLAGS=${arg#*=} ;;
        LDFLAGS=*)        LDFLAGS=${arg#*=} ;;
        -h|--help)        usage; exit 0 ;;
        *) echo "configure: error: unrecognized option: $arg" >&2
           echo "Try './configure --help' for more information." >&2
           exit 1 ;;
    esac
done

# ----- derive directories -------------------------------------------------
: "${exec_prefix:=$prefix}"
: "${bindir:=$exec_prefix/bin}"
: "${datarootdir:=$prefix/share}"
: "${datadir:=$datarootdir}"
: "${mandir:=$datarootdir/man}"
: "${docdir:=$datarootdir/doc/$PKG}"

# ----- locate a working C compiler ---------------------------------------
if [ -z "$CC" ]; then
    for cand in cc gcc clang; do
        if command -v "$cand" >/dev/null 2>&1; then CC=$cand; break; fi
    done
fi
if [ -z "$CC" ]; then
    echo "configure: error: no C compiler found (set CC=...)" >&2
    exit 1
fi

printf 'checking for a working C compiler (%s)... ' "$CC"
tmpc=$(mktemp 2>/dev/null || echo "./conftest.$$.c"); tmpc="${tmpc%.c}.c"
tmpx="${tmpc%.c}.out"
trap 'rm -f "$tmpc" "$tmpx"' EXIT INT TERM
printf 'int main(void){return 0;}\n' > "$tmpc"
if $CC $CFLAGS -o "$tmpx" "$tmpc" >/dev/null 2>&1; then
    echo yes
else
    echo no
    echo "configure: error: C compiler '$CC' cannot build a trivial program" >&2
    exit 1
fi

# Default optimisation/warning flags only when the user gave none.
if [ -z "$CFLAGS" ]; then
    CFLAGS="-O2 -std=c99 -Wall -Wextra -Wno-unused-parameter -Wno-unused-variable -Wno-unused-function -Wno-unused-but-set-variable -Wno-format-truncation"
fi

# ----- emit config.mk -----------------------------------------------------
cat > config.mk <<EOF
# Generated by ./configure -- do not edit. Re-run ./configure to regenerate.
PACKAGE     = $PKG
CC          = $CC
CFLAGS      = $CFLAGS
LDFLAGS     = $LDFLAGS

prefix      = $prefix
exec_prefix = $exec_prefix
bindir      = $bindir
datarootdir = $datarootdir
datadir     = $datadir
mandir      = $mandir
docdir      = $docdir

# clax's own data root: \$(datadir)/clax/ holds system/*.cx
claxdatadir = \$(datadir)/$PKG
EOF

cat <<EOF

clax configured:

  CC         $CC
  CFLAGS     $CFLAGS
  LDFLAGS    ${LDFLAGS:-(none)}

  prefix     $prefix
  bindir     $bindir
  datadir    $datadir/$PKG      (system/*.cx)
  mandir     $mandir
  docdir     $docdir

Now run:  make && sudo make install
EOF
