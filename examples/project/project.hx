#ifndef PROJECT_HX
#define PROJECT_HX
/* project.hx — project-wide constants, macros, typedefs.
 * This is the only hand-written header allowed in a Clax
 * project; everything else is a `.cx` class. The transpiler
 * copies this file to generated_c/project.h on each run, and
 * clax_runtime.h `#include`s it so every generated
 * translation unit sees its contents. */
#endif
